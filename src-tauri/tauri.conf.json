{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "字符画工作台",
  "version": "0.2.1",
  "identifier": "com.local.ascii-art-converter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "字符画工作台",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "externalBin": ["bin/ffmpeg"],
    "targets": "all"
  }
}
